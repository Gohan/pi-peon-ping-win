{
  "name": "@baozs/pi-peon-ping-win",
  "version": "1.2.0",
  "description": "Pi extension for peon-ping sound notifications — fork with native Windows support (ffplay/mpv + winmm.dll PlaySound fallback)",
  "keywords": [
    "pi-package",
    "peon-ping",
    "windows",
    "pi-extension"
  ],
  "type": "module",
  "license": "MIT",
  "author": "cppgohan",
  "contributors": [
    "Josh Thomas <josh@joshuadavidthomas.com> (original pi-peon-ping)"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Gohan/pi-peon-ping-win.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@earendil-works/pi-agent-core": "^0.79.7",
    "@types/node": "^25.9.3",
    "typescript": "^5.0.0",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.74.0",
    "@earendil-works/pi-tui": ">=0.74.0"
  }
}
