{
  "name": "@baozs/pi-peon-ping-win",
  "version": "1.1.0",
  "description": "Pi extension for peon-ping sound notifications — fork with native Windows support (ffplay/mpv + winmm.dll PlaySound fallback)",
  "keywords": [
    "pi-package",
    "peon-ping",
    "windows",
    "pi-extension"
  ],
  "type": "module",
  "license": "MIT",
  "author": "cppgohan",
  "contributors": [
    "Josh Thomas <josh@joshuadavidthomas.com> (original pi-peon-ping)"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Gohan/pi-peon-ping-win.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "test": "bun test tests/",
    "test:watch": "bun test tests/ --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": ">=0.50.0",
    "@mariozechner/pi-tui": ">=0.50.0"
  }
}
